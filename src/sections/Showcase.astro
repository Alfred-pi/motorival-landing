---
import { t, type Locale } from "../i18n/utils";
import { asset } from "../lib/asset";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const dict = t(locale);

// Repeat the screens to fill the marquee track.
const SCREENS = [
  { src: asset("/screens/map.png"), caption: dict.showcase.captions[0] },
  { src: asset("/screens/leaderboard.png"), caption: dict.showcase.captions[1] },
  { src: asset("/screens/profile.png"), caption: dict.showcase.captions[2] },
  { src: asset("/screens/summary.png"), caption: dict.showcase.captions[3] },
  { src: asset("/screens/riding.png"), caption: dict.showcase.captions[0] },
  { src: asset("/screens/riding-alt.png"), caption: dict.showcase.captions[3] },
];
// Two copies → CSS translateX(-50%) loops seamlessly.
const TRACK = [...SCREENS, ...SCREENS];
---

<section class="showcase relative py-24 md:py-32 border-t border-[var(--color-line)] overflow-hidden">
  <div aria-hidden="true" class="absolute inset-0 -z-10 spotlight-2"></div>

  <div class="mx-auto max-w-[1320px] px-6 md:px-10">
    <header class="mb-14 md:mb-20 text-center reveal reveal-stagger">
      <span class="eyebrow text-[var(--color-accent)] block mb-4">{dict.showcase.eyebrow}</span>
      <h2 class="font-display italic text-[clamp(34px,5.5vw,72px)] leading-[1.02] mb-5 max-w-[20ch] mx-auto">
        {dict.showcase.title}
      </h2>
      <p class="text-[var(--color-muted)] text-base md:text-lg max-w-[55ch] mx-auto">
        {dict.showcase.sub}
      </p>
    </header>
  </div>

  <!-- Infinite marquee track. Pauses on hover. -->
  <div
    class="showcase-marquee relative reveal"
    style="mask-image: linear-gradient(90deg, transparent, #000 6%, #000 94%, transparent);"
  >
    <div class="showcase-track">
      {TRACK.map((s, i) => (
        <figure class="shrink-0 flex flex-col items-center gap-4 w-[180px] sm:w-[220px] md:w-[260px]">
          <div class="relative w-full">
            <div
              aria-hidden="true"
              class="device-glow"
              style="background: radial-gradient(circle at 50% 50%, rgba(255,23,68,0.45) 0%, transparent 70%);"
            ></div>
            <img
              src={s.src}
              alt={s.caption}
              class="screen-shot w-full h-auto block"
              loading={i < 4 ? "eager" : "lazy"}
              decoding="async"
            />
          </div>
          <figcaption class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-muted)] text-center">
            {s.caption}
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .showcase-marquee { overflow: hidden; }
  .showcase-track {
    display: flex;
    gap: 1.75rem;
    width: max-content;
    animation: showcaseScroll 50s linear infinite;
    will-change: transform;
  }
  .showcase-marquee:hover .showcase-track { animation-play-state: paused; }
  @keyframes showcaseScroll {
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .showcase-track { animation: none; }
  }
</style>
