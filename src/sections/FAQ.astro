---
import { t, type Locale } from "../i18n/utils";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const dict = t(locale);
---

<section id="faq" class="py-24 md:py-32 border-t border-[var(--color-line)]">
  <div class="mx-auto max-w-[920px] px-6 md:px-10">
    <header class="mb-12 md:mb-16 reveal reveal-stagger">
      <span class="eyebrow text-[var(--color-accent)] block mb-4">{dict.faq.eyebrow}</span>
      <h2 class="font-display text-[clamp(34px,5vw,64px)] leading-[1.05]">
        {dict.faq.title}
      </h2>
    </header>

    <div class="border-t border-[var(--color-line)]">
      {dict.faq.items.map((item, i) => (
        <details class="group border-b border-[var(--color-line)] reveal" {...(i === 0 ? { open: true } : {})}>
          <summary
            class="list-none cursor-pointer flex items-center justify-between py-5 md:py-6 text-left font-display text-lg md:text-xl hover:text-[var(--color-accent)] transition-colors select-none"
          >
            <span>{item.q}</span>
            <span
              aria-hidden="true"
              class="text-[var(--color-accent)] text-3xl font-light leading-none ml-4 transition-transform duration-200 group-open:rotate-45"
            >+</span>
          </summary>
          <div class="overflow-hidden">
            <p class="pb-6 text-[var(--color-muted)] leading-relaxed max-w-[70ch]">
              {item.a}
            </p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  details summary::-webkit-details-marker { display: none; }
</style>
