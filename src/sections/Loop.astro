---
import { t, type Locale } from "../i18n/utils";
import DeviceMockup from "../components/DeviceMockup.astro";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const dict = t(locale);

const screens = ["/screens/riding.png", "/screens/leaderboard.png", "/screens/profile.png"];
---

<section id="loop" class="relative py-24 md:py-36 overflow-hidden">
  <div aria-hidden="true" class="absolute inset-0 -z-10 spotlight-2"></div>

  <div class="mx-auto max-w-[1320px] px-6 md:px-10">
    <header class="mb-20 md:mb-28 reveal reveal-stagger">
      <span class="eyebrow text-[var(--color-accent)] block mb-4">{dict.loop.eyebrow}</span>
      <h2 class="font-display text-[clamp(36px,5.5vw,72px)] leading-[1.05] max-w-[20ch]">
        {dict.loop.title}
      </h2>
    </header>

    <div class="space-y-28 md:space-y-40">
      {dict.loop.steps.map((s, i) => (
        <div
          class={`grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-20 items-center reveal reveal-stagger ${
            i % 2 === 1 ? "lg:[direction:rtl]" : ""
          }`}
        >
          <div class={i % 2 === 1 ? "lg:[direction:ltr]" : ""}>
            <span class="font-display text-sm text-[var(--color-accent)] tracking-wide block mb-4">
              {s.num} · {s.eyebrow}
            </span>
            <h3 class="font-display text-[clamp(28px,4.5vw,56px)] leading-[1.05] mb-5 whitespace-pre-line">
              {s.title}
            </h3>
            <p class="text-[var(--color-muted)] text-base md:text-lg leading-relaxed max-w-[48ch]">
              {s.desc}
            </p>
          </div>

          <div class={`flex justify-center ${i % 2 === 1 ? "lg:[direction:ltr]" : ""}`}>
            <DeviceMockup
              src={screens[i]}
              alt={s.title}
              size="lg"
              tilt={i % 2 === 0 ? -3 : 3}
              glow={i === 1 ? "gold" : "red"}
            />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
