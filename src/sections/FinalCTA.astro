---
import { t, type Locale } from "../i18n/utils";
import AppStoreBadge from "../components/AppStoreBadge.astro";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const dict = t(locale);
---

<section
  id="cta"
  class="relative py-28 md:py-44 border-t border-[var(--color-line)] overflow-hidden"
>
  <div aria-hidden="true" class="absolute inset-0 -z-10 spotlight"></div>
  <div aria-hidden="true" class="absolute inset-0 -z-10 hex-grid opacity-40"></div>

  <div class="relative mx-auto max-w-[1320px] px-6 md:px-10 text-center reveal reveal-stagger">
    <span class="eyebrow text-[var(--color-accent)] block mb-5">{dict.finalCta.eyebrow}</span>

    <h2 class="font-display text-[clamp(44px,9vw,128px)] leading-[0.92] mb-7 max-w-[16ch] mx-auto">
      <span class="block">{dict.finalCta.title[0]}</span>
      <span class="block text-[var(--color-accent)]">{dict.finalCta.title[1]}</span>
    </h2>

    <p class="text-base md:text-lg text-[color-mix(in_oklab,var(--color-text)_85%,transparent)] max-w-[55ch] mx-auto mb-10">
      {dict.finalCta.sub}
    </p>

    <div class="inline-flex flex-col items-center gap-3">
      <AppStoreBadge locale={locale} />
      <p class="text-xs text-[var(--color-muted)] tracking-wider">{dict.finalCta.note}</p>
      <p class="text-xs text-[color-mix(in_oklab,var(--color-muted)_60%,transparent)] tracking-wider">
        {dict.finalCta.soon}
      </p>
    </div>
  </div>
</section>
