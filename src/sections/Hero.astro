---
import { t, type Locale } from "../i18n/utils";
import AppStoreBadge from "../components/AppStoreBadge.astro";

interface Props { locale: Locale; }
const { locale } = Astro.props;
const dict = t(locale);

// SWAP later with a self-hosted shot (e.g. /media/hero-motard.jpg).
// Unsplash CDN auto-resizes via query params; license: free for commercial use.
const HERO_IMAGE =
  "https://images.unsplash.com/photo-1558981806-ec527fa84c39?w=2400&q=80&auto=format&fit=crop";

// When the screencast is exported drop it in /public/media/hero.mp4 and uncomment.
const HERO_VIDEO_MP4: string | undefined = undefined;
---

<section class="hero relative w-full overflow-hidden">
  <!-- ───── Background: cinematic motard photo ───── -->
  <div aria-hidden="true" class="hero-bg absolute inset-0 -z-10">
    {HERO_VIDEO_MP4 ? (
      <video
        class="hero-media absolute inset-0 w-full h-full object-cover"
        autoplay
        loop
        muted
        playsinline
        preload="metadata"
        poster={HERO_IMAGE}
      >
        <source src={HERO_VIDEO_MP4} type="video/mp4" />
      </video>
    ) : (
      <img
        src={HERO_IMAGE}
        alt=""
        class="hero-media absolute inset-0 w-full h-full object-cover"
        loading="eager"
        decoding="async"
        fetchpriority="high"
      />
    )}

    <!-- Layered overlays (theme-aware) -->
    <div class="hero-overlay-base absolute inset-0"></div>
    <div class="hero-overlay-vignette absolute inset-0"></div>
    <div class="hex-grid absolute inset-0 opacity-25 mix-blend-screen"></div>
    <div aria-hidden="true" class="hero-scanline"></div>
    <div aria-hidden="true" class="hero-spot-accent"></div>
  </div>

  <!-- ───── Content ───── -->
  <div class="relative mx-auto max-w-[1320px] px-6 md:px-10 min-h-[calc(100svh-60px)] flex flex-col justify-center pt-12 md:pt-16 pb-24 md:pb-32">
    <div class="reveal reveal-stagger max-w-[1100px]">
      <span class="inline-flex items-center gap-2.5 px-3 py-1.5 rounded-full text-[11px] font-semibold tracking-[0.18em] uppercase text-white mb-8 backdrop-blur-md"
        style="background: rgba(0,0,0,0.45); border: 1px solid rgba(255,255,255,0.12);"
      >
        <span class="live-dot" aria-hidden="true"></span>
        <span>{dict.hero.eyebrow}</span>
      </span>

      <h1 class="hero-headline font-display italic text-white">
        <span class="hero-line block">{dict.hero.headline[0]}</span>
        <span class="hero-line block accent">{dict.hero.headline[1]}</span>
        <span class="hero-line block">{dict.hero.headline[2]}</span>
      </h1>

      <p class="text-base sm:text-lg md:text-xl text-white/80 leading-snug max-w-[52ch] mt-7 mb-10">
        {dict.hero.sub}
      </p>

      <div class="flex flex-wrap gap-4 items-center mb-12">
        <AppStoreBadge locale={locale} height={54} />
      </div>

      <div class="flex flex-wrap gap-x-7 gap-y-2 text-[11px] tracking-[0.14em] uppercase text-white/55 font-semibold">
        <span>{dict.hero.chips.ios}</span>
        <span aria-hidden="true">·</span>
        <span>{dict.hero.chips.languages}</span>
        <span aria-hidden="true">·</span>
        <span>{dict.hero.chips.gps}</span>
        <span aria-hidden="true">·</span>
        <span>{dict.hero.chips.privacy}</span>
      </div>
    </div>
  </div>

  <!-- ───── Bottom marquee — trust strip ───── -->
  <div class="hero-marquee absolute inset-x-0 bottom-0 py-4 marquee">
    <div class="marquee-track text-white/55 text-[11px] tracking-[0.22em] uppercase font-semibold">
      {Array.from({ length: 2 }).map(() => (
        <div class="flex gap-12 items-center shrink-0">
          {dict.hero.trust.map((label, i) => (
            <>
              <span>{label}</span>
              {i < dict.hero.trust.length - 1 && <span aria-hidden="true" class="text-[var(--color-accent)]">●</span>}
            </>
          ))}
          <span aria-hidden="true" class="text-[var(--color-accent)]">●</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .hero {
    /* Sit under the fixed nav (60px) and span the rest of the viewport */
    min-height: calc(100svh - 60px);
    isolation: isolate; /* keep mix-blend-screen scoped */
  }

  /* ───── Media base ───── */
  .hero-media {
    transform: scale(1.06);
    animation: heroPan 24s ease-in-out infinite alternate;
    filter: contrast(1.05) saturate(0.95);
  }
  @keyframes heroPan {
    0%   { transform: scale(1.06) translate3d(-1.2%, -0.6%, 0); }
    100% { transform: scale(1.10) translate3d( 1.2%,  0.6%, 0); }
  }

  /* ───── Overlays (dark mode default) ───── */
  .hero-overlay-base {
    background:
      linear-gradient(
        180deg,
        rgba(7, 8, 12, 0.55) 0%,
        rgba(7, 8, 12, 0.45) 35%,
        rgba(7, 8, 12, 0.85) 75%,
        var(--color-bg) 100%
      );
  }
  .hero-overlay-vignette {
    background:
      radial-gradient(ellipse at center, transparent 0%, transparent 35%, rgba(0,0,0,0.6) 100%);
    pointer-events: none;
  }
  .hero-spot-accent {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 32%, rgba(255,23,68,0.22) 0%, transparent 35%),
      radial-gradient(circle at 88% 78%, rgba(255,23,68,0.10) 0%, transparent 40%);
    mix-blend-mode: screen;
    animation: heroPulse 8s ease-in-out infinite;
    pointer-events: none;
  }
  @keyframes heroPulse {
    0%, 100% { opacity: 0.85; }
    50%      { opacity: 1; }
  }
  .hero-scanline {
    position: absolute;
    left: 0;
    right: 0;
    height: 28%;
    top: -28%;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(255,255,255,0.025) 45%,
      rgba(255,23,68,0.06) 50%,
      rgba(255,255,255,0.025) 55%,
      transparent 100%
    );
    animation: heroScan 14s linear infinite;
    pointer-events: none;
    will-change: transform;
  }
  @keyframes heroScan {
    0%   { transform: translateY(0); }
    100% { transform: translateY(380%); }
  }

  /* Light-mode dampening — keep the photo readable, less dark */
  :global([data-theme="light"]) .hero-overlay-base {
    background:
      linear-gradient(
        180deg,
        rgba(7, 8, 12, 0.35) 0%,
        rgba(7, 8, 12, 0.30) 35%,
        rgba(7, 8, 12, 0.65) 75%,
        var(--color-bg) 100%
      );
  }

  /* ───── Headline ───── */
  .hero-headline {
    font-size: clamp(56px, 11vw, 168px);
    line-height: 0.86;
    letter-spacing: -0.03em;
    font-weight: 900;
    font-style: italic;
    text-shadow: 0 24px 48px rgba(0, 0, 0, 0.5);
  }
  .hero-line {
    transform: translateY(0);
    transition: color 200ms var(--ease-soft);
  }
  .hero-line.accent {
    color: var(--color-accent);
    text-shadow:
      0 0 24px color-mix(in oklab, var(--color-accent) 30%, transparent),
      0 24px 48px rgba(0, 0, 0, 0.5);
  }

  /* Reveal letter-by-line on first paint (cinematic stagger) */
  .reveal-stagger .hero-line {
    opacity: 0;
    transform: translate3d(-2vw, 0, 0);
    transition:
      opacity 800ms var(--ease-spring),
      transform 800ms var(--ease-spring);
  }
  .reveal-stagger.is-visible .hero-line:nth-child(1) { transition-delay: 80ms;  opacity: 1; transform: none; }
  .reveal-stagger.is-visible .hero-line:nth-child(2) { transition-delay: 220ms; opacity: 1; transform: none; }
  .reveal-stagger.is-visible .hero-line:nth-child(3) { transition-delay: 360ms; opacity: 1; transform: none; }

  /* Marquee gets its own dark band so the photo doesn't bleed text */
  .hero-marquee {
    background: linear-gradient(180deg, transparent, rgba(0,0,0,0.55));
    border-top: 1px solid rgba(255,255,255,0.06);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-media,
    .hero-spot-accent,
    .hero-scanline { animation: none; }
  }
</style>
