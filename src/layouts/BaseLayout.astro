---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { t, type Locale, alternates, localePath } from "../i18n/utils";
import { LOCALE_HREFLANG } from "../i18n/ui";

interface Props {
  locale: Locale;
  /** Override the page title; defaults to the locale's home title. */
  title?: string;
  /** Override the page meta description. */
  description?: string;
  /** Path to use for hreflang alternates, e.g. "/" or "/privacy". */
  pagePath?: string;
}

const { locale, title, description, pagePath = "/" } = Astro.props;
const dict = t(locale);

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const canonical = `${siteUrl}${localePath(locale, pagePath)}`;
const alts = alternates(siteUrl, pagePath);

const pageTitle = title ?? dict.meta.title;
const pageDescription = description ?? dict.meta.description;

// JSON-LD MobileApplication
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MobileApplication",
  name: "MotoRival",
  description: dict.meta.description,
  applicationCategory: ["SportsApplication", "GameApplication"],
  operatingSystem: "iOS",
  url: siteUrl || undefined,
  inLanguage: LOCALE_HREFLANG[locale],
  offers: {
    "@type": "Offer",
    priceCurrency: "USD",
    price: "0",
  },
  publisher: {
    "@type": "Organization",
    name: "AppSprint Studio",
    url: "https://appsprint.dev",
  },
};
---

<!doctype html>
<html lang={locale} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonical} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#07080C" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#FAFAFA" media="(prefers-color-scheme: light)" />

    <!-- hreflang alternates -->
    {alts.map((a) => (
      <link rel="alternate" hreflang={LOCALE_HREFLANG[a.locale]} href={a.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}${pagePath}`} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={dict.meta.ogTitle} />
    <meta property="og:description" content={dict.meta.ogDescription} />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:locale" content={LOCALE_HREFLANG[locale].replace("-", "_")} />
    <meta property="og:site_name" content="MotoRival" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={dict.meta.ogTitle} />
    <meta name="twitter:description" content={dict.meta.ogDescription} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link
      href="https://api.fontshare.com/v2/css?f[]=satoshi@900,700,500&display=swap"
      rel="stylesheet"
    />

    <!-- Theme init + body lock (must run before paint to avoid flash). Light by default. -->
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem("motorival.theme");
          var sysDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          var theme = stored || (sysDark ? "dark" : "light");
          document.documentElement.dataset.theme = theme;
        } catch (e) {
          document.documentElement.dataset.theme = "light";
        }
        // Lock scroll while loader is visible
        document.documentElement.classList.add("loading");
      })();
    </script>

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <!-- Page loader — fades out once the page has loaded -->
    <div id="page-loader" aria-hidden="true">
      <div class="page-loader-mark">
        <img src="/logo-dark.svg" class="logo-dark" alt="" width="auto" height="44" style="height:44px;width:auto;" />
        <img src="/logo-light.svg" class="logo-light" alt="" width="auto" height="44" style="height:44px;width:auto;" />
      </div>
      <div class="page-loader-bar"><span></span></div>
    </div>

    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:px-3 focus:py-2 focus:bg-[var(--color-bg-3)] focus:text-[var(--color-text)] focus:rounded-md"
    >
      {dict.nav.skipToContent}
    </a>

    <Nav locale={locale} pagePath={pagePath} />

    <main id="main">
      <slot />
    </main>

    <Footer locale={locale} />

    <!-- App Store toast — singleton, fired by any [data-appstore-trigger] -->
    <div
      id="appstore-toast"
      class="fixed bottom-6 left-1/2 -translate-x-1/2 px-6 py-4 rounded-xl font-medium text-sm tracking-wide shadow-2xl z-[200] surface text-[var(--color-text)] opacity-0 translate-y-6 pointer-events-none transition-all duration-300"
      role="status"
      aria-live="polite"
    >
      {dict.badge.soon}
    </div>

    <!-- Reveal-on-scroll observer + AppStore trigger + Loader release -->
    <script is:inline>
      (function () {
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                io.unobserve(e.target);
              }
            });
          },
          { rootMargin: "-40px 0px -40px 0px", threshold: 0.1 }
        );
        document.querySelectorAll(".reveal").forEach(function (el) { io.observe(el); });

        var toast = document.getElementById("appstore-toast");
        var hideTimer = null;
        document.querySelectorAll("[data-appstore-trigger]").forEach(function (el) {
          el.addEventListener("click", function (e) {
            e.preventDefault();
            if (!toast) return;
            toast.style.opacity = "1";
            toast.style.transform = "translate(-50%, 0)";
            if (hideTimer) clearTimeout(hideTimer);
            hideTimer = setTimeout(function () {
              toast.style.opacity = "0";
              toast.style.transform = "translate(-50%, 1.5rem)";
            }, 3500);
          });
        });

        // Release the loader after window load + min splash time
        var loader = document.getElementById("page-loader");
        var minSplash = 1800; // total dwell with anim
        var start = performance.now();
        function releaseLoader() {
          var elapsed = performance.now() - start;
          var wait = Math.max(0, minSplash - elapsed);
          setTimeout(function () {
            if (loader) loader.classList.add("is-done");
            document.documentElement.classList.remove("loading");
            document.documentElement.classList.add("loaded");
          }, wait);
        }
        if (document.readyState === "complete") releaseLoader();
        else window.addEventListener("load", releaseLoader, { once: true });
      })();
    </script>
  </body>
</html>
