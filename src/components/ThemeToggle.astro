---
import { t, type Locale } from "../i18n/utils";
interface Props { locale: Locale; }
const { locale } = Astro.props;
const dict = t(locale);
---

<button
  type="button"
  data-theme-toggle
  class="inline-flex items-center justify-center w-9 h-9 rounded-lg surface text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors"
  aria-label={dict.nav.toggleTheme}
  title={dict.nav.toggleTheme}
>
  <!-- Sun icon (shown in dark mode → click goes to light) -->
  <svg
    class="theme-icon-sun"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>
  <!-- Moon icon (shown in light mode → click goes to dark) -->
  <svg
    class="theme-icon-moon"
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<style>
  /* Show only the icon that points to the *next* state */
  :global([data-theme="dark"]) .theme-icon-moon { display: none; }
  :global([data-theme="light"]) .theme-icon-sun { display: none; }
  :global(:root:not([data-theme="light"])) .theme-icon-moon { display: none; }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>("[data-theme-toggle]");
  if (btn) {
    btn.addEventListener("click", () => {
      const root = document.documentElement;
      const next = root.dataset.theme === "light" ? "dark" : "light";
      root.dataset.theme = next;
      try {
        localStorage.setItem("motorival.theme", next);
      } catch {}
    });
  }
</script>
