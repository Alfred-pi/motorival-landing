---
import { t, type Locale } from "../i18n/utils";
interface Props {
  locale: Locale;
  className?: string;
  /** Visual height of the badge in px (Apple guidelines: ≥ 40px). */
  height?: number;
}
const { locale, className = "", height = 48 } = Astro.props;
const dict = t(locale);
---

<a
  href="#"
  data-appstore-trigger
  class={`appstore-badge inline-flex transition-transform duration-200 hover:-translate-y-0.5 ${className}`}
  aria-label={dict.badge.aria}
  style={`height: ${height}px;`}
>
  <img
    src={`${import.meta.env.BASE_URL}badges/app-store-en.svg`}
    alt={dict.badge.aria}
    height={height}
    style={`height: ${height}px; width: auto;`}
    loading="eager"
    decoding="async"
  />
</a>

<style>
  .appstore-badge {
    border-radius: 10px;
  }
  .appstore-badge img {
    border-radius: 10px;
    transition: filter 200ms var(--ease-soft);
  }
  .appstore-badge:hover img {
    filter: drop-shadow(0 0 16px color-mix(in oklab, var(--color-accent) 35%, transparent));
  }
</style>
